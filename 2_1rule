    """Create database records for each encoded video"""
    asset_id = context['asset_record']['id']
    moved_files = context['moved_encodes']
    
    encode_records = []
    
    for encoded in moved_files:
        record = {
            'id': f"encode_{encoded['profile']}_{datetime.now().strftime('%Y%m%d%H%M%S')}",
            'asset_id': asset_id,
            'profile': encoded['profile'],
            'path': encoded['destination'],
            'size': encoded['size'],
            'created_at': datetime.now().isoformat(),
            'status': 'ready'
        }
        encode_records.append(record)
    
    # In real implementation, insert into database
    # db.insert('encoded_videos', encode_records)
    
    # For demo, save to JSON file
    table_path = context.get('encode_table', './encode_table.json')
    
    # Load existing records
    records = []
    if os.path.exists(table_path):
        with open(table_path, 'r') as f:
            records = json.load(f)
    
    records.extend(encode_records)
    
    with open(table_path, 'w') as f:
        json.dump(records, f, indent=2)
    
    context['encode_records'] = encode_records
    return f"Created {len(encode_records)} encode records in database"


def update_asset_status(context: Dict[str, Any]) -> str:
    """Update the original asset record with encoding completion status"""
    asset_id = context['asset_record']['id']
    
    # Load asset table
    table_path = context.get('asset_table', './asset_table.json')
    
    with open(table_path, 'r') as f:
        records = json.load(f)
    
    # Find and update the asset
    for record in records:
        if record['id'] == asset_id:
            record['encoding_status'] = 'completed'
            record['encoding_completed_at'] = datetime.now().isoformat()
            record['available_profiles'] = [e['profile'] for e in context['encode_records']]
            break
    
    with open(table_path, 'w') as f:
        json.dump(records, f, indent=2)
    
    return f"Updated asset {asset_id} encoding status"


# ==================== DAG BUILDERS ====================

def build_ingest_dag() -> DAG:
    """Build the video ingest DAG"""
    dag = DAG("video_ingest")
    
    dag.add_task(Task(
        name="validate_video",
        function=validate_video,
        dependencies=[]
    ))
    
    dag.add_task(Task(
        name="extract_metadata",
        function=extract_metadata,
        dependencies=["validate_video"]
    ))
    
    dag.add_task(Task(
        name="quality_check",
        function=quality_check,
        dependencies=["extract_metadata"]
    ))
    
    dag.add_task(Task(
        name="transcode_video",
        function=transcode_video,
        dependencies=["quality_check"]
    ))
    
    dag.add_task(Task(
        name="generate_thumbnail",
        function=generate_thumbnail,
        dependencies=["extract_metadata"]
    ))
    
    dag.add_task(Task(
        name="move_to_asset_bucket",
        function=move_to_asset_bucket,
        dependencies=["transcode_video", "generate_thumbnail"]
    ))
    
    dag.add_task(Task(
        name="add_to_asset_table",
        function=add_to_asset_table,
        dependencies=["move_to_asset_bucket"]
    ))
    
    return dag


def build_transcode_dag() -> DAG:
    """Build the transcoding DAG based on inspection"""
    dag = DAG("video_transcode")
    
    dag.add_task(Task(
        name="inspect_source",
        function=inspect_source_video,
        dependencies=[]
    ))
    
    dag.add_task(Task(
        name="create_encode_jobs",
        function=create_encode_jobs,
        dependencies=["inspect_source"]
    ))
    
    # Parallel encoding tasks
    dag.add_task(Task(
        name="encode_1080p",
        function=encode_1080p,
        dependencies=["create_encode_jobs"]
    ))
    
    dag.add_task(Task(
        name="encode_720p",
        function=encode_720p,
        dependencies=["create_encode_jobs"]
    ))
    
    dag.add_task(Task(
        name="encode_480p",
        function=encode_480p,
        dependencies=["create_encode_jobs"]
    ))
    
    dag.add_task(Task(
        name="encode_4k",
        function=encode_4k,
        dependencies=["create_encode_jobs"]
    ))
    
    # Validation and storage
    dag.add_task(Task(
        name="validate_encodes",
        function=validate_encodes,
        dependencies=["encode_1080p", "encode_720p", "encode_480p", "encode_4k"]
    ))
    
    dag.add_task(Task(
        name="move_to_encoded_bucket",
        function=move_to_encoded_bucket,
        dependencies=["validate_encodes"]
    ))
    
    dag.add_task(Task(
        name="create_encode_records",
        function=create_encode_records,
        dependencies=["move_to_encoded_bucket"]
    ))
    
    dag.add_task(Task(
        name="update_asset_status",
        function=update_asset_status,
        dependencies=["create_encode_records"]
    ))
    
    return dag


