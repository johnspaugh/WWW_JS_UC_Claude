def quality_check(context: Dict[str, Any]) -> str:
    """Perform quality checks on the video"""
    metadata = context['metadata']
    
    # Check resolution
    if metadata['resolution'] not in ['1920x1080', '3840x2160', '1280x720']:
        raise ValueError(f"Unsupported resolution: {metadata['resolution']}")
    
    # Check duration
    if metadata['duration'] < 1:
        raise ValueError("Video too short")
    
    return "Quality check passed"


