def inspect_source_video(context: Dict[str, Any]) -> str:
    """Inspect the ingested video to determine transcoding requirements"""
    metadata = context['metadata']
    
    # Determine what profiles/formats to encode based on source
    encode_profiles = []
    
    source_width = metadata['width']
    source_height = metadata['height']
    
    # Always create these profiles if source supports them
    if source_height >= 1080:
        encode_profiles.append({
            'name': '1080p',
            'width': 1920,
            'height': 1080,
            'video_bitrate': 5000000,
            'audio_bitrate': 128000
        })
    
    if source_height >= 720:
        encode_profiles.append({
            'name': '720p',
            'width': 1280,
            'height': 720,
            'video_bitrate': 2500000,
            'audio_bitrate': 128000
        })
    
    if source_height >= 480:
        encode_profiles.append({
            'name': '480p',
            'width': 854,
            'height': 480,
            'video_bitrate': 1000000,
            'audio_bitrate': 96000
        })
    
    # Add 4K if source is 4K
    if source_height >= 2160:
        encode_profiles.append({
            'name': '4K',
            'width': 3840,
            'height': 2160,
            'video_bitrate': 15000000,
            'audio_bitrate': 192000
        })
    
    context['encode_profiles'] = encode_profiles
    return f"Inspection complete: {len(encode_profiles)} profiles identified - {[p['name'] for p in encode_profiles]}"


def create_encode_jobs(context: Dict[str, Any]) -> str:
    """Create individual encode jobs for each profile"""
    profiles = context['encode_profiles']
    
    jobs = []
    for profile in profiles:
        job = {
            'id': f"job_{profile['name']}_{datetime.now().strftime('%Y%m%d%H%M%S')}",
            'profile': profile,
            'status': 'created',
            'source_path': context['asset_path']
        }
        jobs.append(job)
    
    context['encode_jobs'] = jobs
    return f"Created {len(jobs)} encode jobs"


